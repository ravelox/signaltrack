{
  "name": "signaltrack",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev:api": "pnpm --filter @signaltrack/api dev",
    "dev:worker": "pnpm --filter @signaltrack/worker dev",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "migrate": "pnpm --filter @signaltrack/infrastructure migrate"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.7.0"
  }
}